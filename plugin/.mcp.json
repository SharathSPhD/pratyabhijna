{
  "mcpServers": {
    "pratyabhijna": {
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "pratyabhijna-creative-engine @ git+https://github.com/SharathSPhD/pratyabhijna.git@main",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/mcp/server.py"
      ],
      "env": {
        "PCE_HAIKU_CLI": "claude",
        "PCE_HAIKU_MODEL": "haiku"
      }
    }
  }
}
