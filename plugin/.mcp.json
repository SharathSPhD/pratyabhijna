{
  "mcpServers": {
    "pratyabhijna": {
      "command": "uv",
      "args": [
        "--directory",
        "${CLAUDE_PLUGIN_ROOT}/..",
        "run",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/mcp/server.py"
      ],
      "env": {
        "PCE_HAIKU_CLI": "claude",
        "PCE_HAIKU_MODEL": "haiku"
      }
    }
  }
}
