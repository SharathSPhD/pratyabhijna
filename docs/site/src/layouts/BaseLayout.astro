---
import '../styles/global.css';
import { NAV, withBase } from '../lib/nav';
import DarkModeToggle from '../components/DarkModeToggle.astro';

interface Props {
  title: string;
  description?: string;
  active?: string;
}

const { title, description, active } = Astro.props as Props;
const fullTitle = `${title} — Pratyabhijñā Creative Engine v0.4`;
const desc = description ?? 'PCE v0.4 — a mechanism study of recursive self-reflexivity layers for LLM creative cognition.';

const groups = NAV.reduce<Record<string, typeof NAV>>((acc, item) => {
  const g = item.group ?? 'Other';
  acc[g] = acc[g] ?? [];
  acc[g].push(item);
  return acc;
}, {});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#fafaf7" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=JetBrains+Mono:wght@400;600&display=swap" />
    <title>{fullTitle}</title>
    <script is:inline>
      // Apply theme before paint to avoid flash
      (function () {
        try {
          const stored = localStorage.getItem('pce-theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored ?? (prefersDark ? 'dark' : 'light');
          if (theme === 'dark') document.documentElement.classList.add('dark');
        } catch {}
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-[var(--accent)] focus:text-white focus:px-3 focus:py-2 focus:rounded"
    >Skip to main content</a>
    <header class="border-b border-[var(--rule)] bg-[var(--bg)] sticky top-0 z-30 backdrop-blur">
      <div class="max-w-[1200px] mx-auto px-5 py-3 flex items-center justify-between gap-4">
        <a href={withBase('/')} class="flex items-baseline gap-2" aria-label="Home">
          <span class="font-serif font-semibold text-lg tracking-tight">Pratyabhijñā Creative Engine</span>
          <span class="tag">v0.4</span>
        </a>
        <nav class="flex items-center gap-3 text-sm" aria-label="Top navigation">
          <a href={withBase('/results')} class="hidden md:inline-block hover:underline">Results</a>
          <a href={withBase('/showcase')} class="hidden md:inline-block hover:underline">Showcase</a>
          <a href={withBase('/plugin')} class="hidden md:inline-block hover:underline">Plugin</a>
          <a href={withBase('/paper/main.pdf')} class="hidden md:inline-block hover:underline">Paper PDF</a>
          <a href="https://github.com/sharathsphd/pratyabhijna" class="hidden md:inline-block hover:underline" rel="noopener" target="_blank">GitHub</a>
          <DarkModeToggle />
        </nav>
      </div>
    </header>

    <div class="max-w-[1200px] mx-auto px-5 py-8">
      <div class="sidebar-grid grid grid-cols-1 md:grid-cols-[220px_1fr] gap-8">
        <aside class="sidebar-nav">
          <nav class="sticky top-20 text-sm" aria-label="Site sections">
            {Object.entries(groups).map(([group, items]) => (
              <div class="mb-5">
                <div class="text-[var(--fg-soft)] uppercase tracking-widest text-[0.7rem] mb-1.5 font-semibold">{group}</div>
                <ul class="space-y-0.5">
                  {items.map(item => (
                    <li>
                      <a
                        href={withBase(item.href)}
                        aria-current={active === item.href ? 'page' : undefined}
                        class:list={[
                          'block px-2 py-1 rounded',
                          active === item.href
                            ? 'bg-[var(--accent-soft)] text-[var(--accent)] font-semibold'
                            : 'hover:bg-[var(--bg-soft)]'
                        ]}
                      >{item.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </nav>
        </aside>

        <main id="main" class="min-w-0 prose-academic max-w-prose">
          <slot />
        </main>
      </div>
    </div>

    <footer class="border-t border-[var(--rule)] mt-12 py-6 text-sm text-[var(--fg-soft)]">
      <div class="max-w-[1200px] mx-auto px-5 flex flex-wrap gap-3 justify-between items-center">
        <span>PCE v0.4 — mechanism study of recursive self-reflexivity layers for LLM creative cognition.</span>
        <span class="flex gap-3">
          <a href="https://open.substack.com/pub/technektar/p/when-the-context-window-is-big-and" rel="noopener" target="_blank" class="hover:underline">Pratyākṣa companion</a>
          <a href={withBase('/references')} class="hover:underline">Bibliography</a>
          <a href="https://github.com/sharathsphd/pratyabhijna" rel="noopener" target="_blank" class="hover:underline">Repository</a>
        </span>
      </div>
    </footer>
  </body>
</html>
