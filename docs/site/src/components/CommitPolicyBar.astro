---
interface Row { policy: string; g: number; ci: [number, number]; n?: number; }
interface Props { rows: Row[]; title?: string; }
const { rows, title } = Astro.props as Props;
const fmt = (x: number, d = 2) => Number.isFinite(x) ? x.toFixed(d) : '—';
const max = Math.max(...rows.map(r => Math.max(Math.abs(r.g), Math.abs(r.ci[0]), Math.abs(r.ci[1]))));
const scale = (x: number) => `${50 + (x / (max * 1.1)) * 50}%`;
---
<div class="card not-prose font-sans my-4">
  {title && <div class="font-semibold text-sm mb-3">{title}</div>}
  <div class="space-y-3">
    {rows.map(r => (
      <div class="grid grid-cols-[160px_1fr_110px] gap-3 items-center text-sm">
        <div class="font-mono text-[0.78rem]">{r.policy}</div>
        <div class="relative h-5 bg-[var(--bg)] border border-[var(--rule)] rounded">
          <div class="absolute top-0 bottom-0 w-px bg-[var(--fg)]" style="left:50%" />
          <div
            class="absolute top-1/2 -translate-y-1/2 h-2 bg-[var(--accent)]/30"
            style={`left:${scale(Math.min(r.ci[0], 0))}; width:calc(${scale(Math.max(r.ci[1], 0))} - ${scale(Math.min(r.ci[0], 0))})`}
          />
          <div class="absolute top-1/2 -translate-y-1/2 w-2.5 h-2.5 -translate-x-1/2 rounded-full bg-[var(--accent)]" style={`left:${scale(r.g)}`} />
        </div>
        <div class="font-mono text-[0.78rem] text-right">{fmt(r.g, 2)} [{fmt(r.ci[0], 2)}, {fmt(r.ci[1], 2)}]</div>
      </div>
    ))}
  </div>
</div>
