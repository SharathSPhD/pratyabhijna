# v0.x snapshot directories may also contain LaTeX build artefacts
paper/**/*.aux
paper/**/*.log
paper/**/*.out
paper/**/*.toc
paper/**/*.bbl
paper/**/*.blg
paper/**/*.synctex.gz
paper/**/main.pdf
# Allow frozen-version main.pdf snapshots (e.g. paper/v0.2/main.pdf, paper/v0.4/main.pdf)
# so the GitHub Pages workflow can serve the canonical PDF without rebuilding LaTeX in CI.
!paper/v0.2/main.pdf
!paper/v0.4/main.pdf

